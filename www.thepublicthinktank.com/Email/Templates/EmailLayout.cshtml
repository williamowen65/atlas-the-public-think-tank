@*
    Email layout for all transactional emails.
    Usage: Set Layout = "EmailLayout" in your email templates.
*@
@{
    Layout = null; // Prevents inheriting the site layout
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] ?? "The Public Think Tank"</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f9f9f9;
            color: #333333;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: auto;
            background: #ffffff;
            border-radius: 8px;
            padding: 20px;
            border: 1px solid #ddd;
        }

        h1 {
            color: #007acc;
        }

        .btn {
            display: inline-block;
            padding: 10px 15px;
            background-color: #007acc;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 4px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        @RenderBody()
    </div>
    <footer>
        @await Html.PartialAsync("~/Views/Shared/_Footer.cshtml");
    </footer>
</body>
</html>