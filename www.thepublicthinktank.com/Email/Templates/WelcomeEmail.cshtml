@using atlas_the_public_think_tank.Email.Models
@model WelcomeEmailModel
@{
    Layout = null; // Ensure no site layout gets pulled in
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Welcome to The Public Think Tank!</title>
    <style>
        /* Keep styles simple and inline-friendly for email clients */
        body {
            font-family: Arial, sans-serif;
            background-color: #f9f9f9;
            color: #333333;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: auto;
            background: #ffffff;
            border-radius: 8px;
            padding: 20px;
            border: 1px solid #ddd;
        }

        h1 {
            color: #007acc;
        }

        .btn {
            display: inline-block;
            padding: 10px 15px;
            background-color: #007acc;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 4px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome, @Model.UserName!</h1>
        <p>
            Thanks for joining <strong>The Public Think Tank</strong>.
            We’re excited to have you on board.
        </p>

        <p>
            To get started, confirm your email by clicking the button below:
        </p>

        <p>
            <a href="@Model.ConfirmationLink" class="btn">Confirm Email</a>
        </p>

        <p>
            If you didn’t sign up, you can safely ignore this email.
        </p>
    </div>
</body>
</html>
