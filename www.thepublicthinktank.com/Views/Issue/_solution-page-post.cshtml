@model Solution_ReadVM
@*
    Solution display partial view
*@
@{
    // Any initialization code can go here
}

<div class="d-flex justify-content-end gap-2 py-2">
    <a href="#" class="btn btn-sm btn-outline-secondary">Share</a>
    <a href="#" class="btn btn-sm btn-outline-secondary">Follow</a>
</div>
<div class="card mb-3" id="solution-@Model.SolutionID">
    <div class="d-flex flex-row">
        <div class="vote-container">
            <!-- Vote mechanism will be loaded here -->
        </div>
        <div class="flex-fill d-flex flex-column">
            <div class="card-header d-flex justify-content-between align-items-center" style="border-left:var(--bs-card-border-width) solid var(--bs-card-border-color); border-top-left-radius: 0;">
                <div>
                    <h5 class="mb-0">@Model.Title</h5>
                    <small class="text-muted">Posted by @Model.Author?.UserName on @Model.CreatedAt.ToString("MMM dd, yyyy")</small>
                </div>
                <div class="text-end d-flex align-items-center gap-1">
                    @if (Model.Issue != null)
                    {
                        <span class="badge bg-primary">For Issue: @Model.Issue.Title</span>
                    }
                </div>
            </div>
            <div class="card-body d-flex flex-column justify-content-between">
                <p>@Model.Content</p>

                @if (Model.Categories != null && Model.Categories.Any())
                {
                    <div class="mt-2">
                        @foreach (var category in Model.Categories)
                        {
                            <span class="badge bg-secondary me-1">@category.CategoryName</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Script for loading the vote mechanism *@
<script>
    document.addEventListener("DOMContentLoaded", () => {
        try {
            const solutionId = '@Model.SolutionID';
            console.log("Fetching vote mechanism for solution:", solutionId);

            fetch(`/api/GetSolutionVotes?solutionId=${solutionId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! Status: ${response.status}`);
                    }
                    return response.text();
                })
                .then(data => {
                    console.log("Solution vote data received:", {solutionId: solutionId, dataLength: data.length});
                    const thisElement = document.querySelector(`#solution-${solutionId}`);
                    if (!thisElement) {
                        console.error(`Element #solution-${solutionId} not found`);
                        return;
                    }

                    const voteContainer = thisElement.querySelector('.vote-container');
                    if (voteContainer) {
                        voteContainer.innerHTML = data;
                        // Initialize voting functionality if needed
                        if (typeof initializeSolutionVoting === 'function') {
                            try {
                                initializeSolutionVoting(solutionId);
                            } catch (initError) {
                                console.error("Error in initializeSolutionVoting:", initError);
                            }
                        }
                    } else {
                        console.error(`Vote container not found in #solution-${solutionId}`);
                    }
                })
                .catch(error => console.error('Error fetching solution votes:', error));
        } catch (outerError) {
            console.error("Error in DOMContentLoaded handler:", outerError);
        }
    });
</script>