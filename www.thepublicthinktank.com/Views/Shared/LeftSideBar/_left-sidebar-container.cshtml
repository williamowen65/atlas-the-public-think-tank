@using atlas_the_public_think_tank.Models.ViewModel
@*
    The left sidebar of the app,
    Present on all pages via the layout file

    This component is fetched via AJAX in order to get content belonging to the sidebar
*@

@model SideBar_ReadVM

<header class="d-flex justify-content-between py-2 px-3 align-items-center">
    <div id="sidebar-headings">
        <h2 id="tree-heading" class="sidebar-heading fs-5 active" style="width: min-content">Issue Categories</h2>
        <h2 id="info-heading" class="sidebar-heading fs-5" style="width: min-content">Page Info</h2>
        <h2 id="filter-heading" class="sidebar-heading fs-5" style="width: min-content">Content Filter</h2>
    </div>
    @Html.Partial("~/Views/Shared/LeftSideBar/_view-mode-toggle.cshtml")
</header>

<hr />

<div id="sidebar-content-container" class="px-3">
    @Html.Partial("~/Views/Shared/LeftSideBar/_categories.cshtml")
    @Html.Partial("~/Views/Shared/LeftSideBar/_page-info.cshtml")
    @Html.Partial("~/Views/Shared/LeftSideBar/_content-filter.cshtml")
</div>


<script src="~/js/dual-slider-input.js" asp-append-version="true"></script>